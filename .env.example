# Base URL of the Twincars Manager instance whose public API powers this website.
# Example: http://localhost:5173 in development, https://manager.twin-cars.de in production.
TC_MANAGER_API_URL=http://localhost:5173

# Bearer token created in the Twincars Manager admin under "Benutzer & Rollen / API-Zugriff".
# Required — the website refuses to start without it.
TC_MANAGER_API_TOKEN=replace-me-with-a-real-token

# Public site URL — used for canonical links, sitemap, og:url, JSON-LD.
PUBLIC_SITE_URL=https://twin-cars.de
